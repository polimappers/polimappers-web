---
import { type CollectionEntry, getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event: CollectionEntry<"events">) => ({
    params: { slug: event.id },
    props: event,
  }));
}

import Layout from "../../layout/Layout.astro";
import { Image } from "astro:assets";

type Props = CollectionEntry<"events">;
const event = Astro.props;
const { Content } = await render(event);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const dateString = event.data.updatedDate
  ? `Published on ${formatDate(event.data.pubDate)} | Updated on ${formatDate(event.data.updatedDate)}`
  : `Published on ${formatDate(event.data.pubDate)}`;
---

<Layout>
  <main>
    <article class="my-8 px-4">
      <div class="mx-auto my-8 px-4 max-w-[75ch]">
        <h1 class="text-6xl font-bold mb-2">
          {event.data.title}
        </h1>
        <p class="text-sm mt-2">{dateString}</p>
      </div>

      <!-- TODO: better alt text -->
      {
        event.data.heroImage && (
          <Image
            src={event.data.heroImage}
            alt={"Cover image for the event: " + event.data.title}
            loading="eager"
            class="max-w-full lg:max-w-5/6 xl:max-w-6xl mx-auto my-4 rounded-lg"
          />
        )
      }

      <div class="mx-auto my-8 px-4 max-w-[75ch]">
        <div class="prose lg:prose-lg max-w-none">
          <Content />
        </div>
      </div>

      {
        event.data.attachments && (
          <div class="mx-auto my-8 px-4 max-w-[75ch]">
            <h2 class="text-2xl font-bold mb-4">Attachments</h2>

            {event.data.attachments.map((attachment) => (
              <a
                href={attachment}
                class="btn btn-primary btn-outline w-full"
                target="_blank"
              >
                Download {attachment.split("/").pop()}
              </a>
            ))}
          </div>
        )
      }
    </article>
  </main>
</Layout>
