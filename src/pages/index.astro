---
import { Image } from "astro:assets";
import logoImg from "../assets/logo.png";

import Layout from "../layout/Layout.astro";
import { map, sampleGrid, simplexNoiseGrid } from "../util/sample-grid";
import IsolinesSvg from "../components/IsolinesSvg.astro";
import EventsList from "../components/EventsList.astro";

import alea from "alea";
import { createNoise2D } from "simplex-noise";

const options = {
  width: 1080,
  height: 720,
  cellSize: 5,
};

const seed = 1;
const scale = 0.01;

const prng = alea(seed);
const noise = createNoise2D(prng);
const grid = sampleGrid((x, y) => {
  const d = y / options.height + 0.15; // simple gradient from top to bottom

  const n1 = map(noise(x * scale, y * scale), -1, 1, 0, 1);
  const n2 = map(noise(x * scale * 2, y * scale * 2), -1, 1, 0, 1);

  return d + n1 * 0.5 + n2 * 0.25; // add noise to the distance, with a weight of 0.5
}, options);
---

<Layout>
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-1">
    <IsolinesSvg
      class="min-w-full h-auto stroke-base-200"
      grid={grid}
      lines={[
        { level: 0.2, dashed: false },
        { level: 0.4, dashed: true },
        { level: 0.6, dashed: false },
        { level: 0.8, dashed: true },
        { level: 1, dashed: false },
      ]}
    />
  </div>

  <main class="hero my-8">
    <div class="hero-content flex-col lg:flex-row-reverse">
      <Image
        src={logoImg}
        loading="eager"
        class="max-w-sm rounded-lg"
        alt="PoliMappers Logo"
      />
      <div>
        <h1 class="text-5xl font-bold">PoliMappers</h1>
        <p class="my-6">
          PoliMappers is a volunteer students' group, based at <a
            href="http://www.polimi.it/"
            target="_blank"
            rel="noopener noreferrer">Politecnico di Milano</a
          >, created in December 2016. The mission of the group is to train and
          motivate the next generation of volunteer mappers and to do mapping
          using free and open source software within the university as well as
          primary and secondary schools.
        </p>

        <p class="my-6">
          PoliMappers is the first European chapter of the international
          association <a
            href="http://www.youthmappers.org/"
            target="_blank"
            rel="noopener noreferrer">YouthMappers</a
          >, founded in 2014 in the United States of America with the support of <a
            href="https://www.usaid.gov/"
            target="_blank"
            rel="noopener noreferrer"
            >United States Agency for International Development</a
          > (USAID). YouthMappers aims to cultivate a new generation of leaders in
          the field of open geospatial data and technologies, with the purpose of
          creating through them resilient communities of the future. It is a global
          network that currently includes 446 chapters in 83 countries (updated 02/2026).
          In accordance with the terms of participation of YouthMappers, the association's
          activities include at least two mapping activities per year: mapping the
          local area and participating in a YouthMappers network promoted campaign.
        </p>
      </div>
    </div>
  </main>

  <div class="max-w-7xl mx-auto px-4 my-8">
    <h2 class="text-3xl font-bold mb-4">Latest Events</h2>
    <p class="mb-6">Check out our latest events and activities.</p>

    <EventsList limit={3} />

    <a href="/events" class="btn btn-primary mt-4">View All Events</a>
  </div>

  <div class="h-[50vh]">
    <!-- temporary space filler -->
  </div>
</Layout>
