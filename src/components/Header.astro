---
const { pathname } = Astro.url;

const links = [
  { href: "/events", text: "Events" },
  { href: "/projects", text: "Projects" },
];
---

<header>
  <nav class="navbar bg-base-200 shadow-sm">
    <div class="navbar-start">
      <a class="btn btn-ghost text-xl" href="/">PoliMappers</a>
    </div>

    <div class="navbar-center">
      <ul class="menu menu-horizontal px-1 space-x-1">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={{ "menu-active": pathname.startsWith(link.href) }}
              >
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="navbar-end">
      <!-- TODO -->
    </div>
  </nav>
</header>
